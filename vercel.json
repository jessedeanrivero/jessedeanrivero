{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/inquiremusic", "destination": "/", "permanent": true },
    { "source": "/inquire", "destination": "/", "permanent": true },
    { "source": "/artists", "destination": "/#work", "permanent": true },
    { "source": "/hillcityrecording", "destination": "/", "permanent": true },
    { "source": "/downloads", "destination": "/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/frames-(desktop|mobile)/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
